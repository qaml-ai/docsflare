{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "docsflare",
  "main": "docs/.docsflare/worker.ts",
  "compatibility_date": "2026-07-16",
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 0.1
    },
    "traces": {
      "enabled": true,
      "head_sampling_rate": 0.05
    }
  }
}
